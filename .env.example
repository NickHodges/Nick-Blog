# Respectify comment moderation service
RESPECTIFY_EMAIL=your-email@example.com
RESPECTIFY_API_KEY=your-respectify-api-key

# Admin authentication credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password

# Session signing secret (use a long random string)
SESSION_SECRET=your-session-secret-at-least-32-characters

# Astro DB / Turso database (optional for local dev, required for production)
# ASTRO_DB_REMOTE_URL=libsql://your-database.turso.io
# ASTRO_DB_APP_TOKEN=your-turso-auth-token
