---
import PostLayout from '@layouts/BlogPost.astro';
import Pagination from '@components/Paginator.astro';
import PostPreview from '@components/blog/PostPreview.astro';
import PageLayout from '@layouts/Base.astro';
import { getAllPosts, getUniqueTags as getPostUniqueTags, sortMDByDate as sortPostsByDate } from '@data/post';
import { getAllDelphiPosts, getUniqueTags as getDelphiUniqueTags, sortMDByDate as sortDelphiByDate } from '@data/delphi';
import 'astro-starlight-remark-asides/styles.css';

export const prerender = false;

// Fetch all posts
const postEntries = await getAllPosts();
const delphiEntries = await getAllDelphiPosts();
const allPosts = [...postEntries, ...delphiEntries];

// Get the slug parameter
const slugParam = Astro.params.slug;

// Check if this is a pagination request (slug is just a number like "2", "3", etc.)
const isPageNumber = slugParam && !slugParam.includes('/') && !isNaN(parseInt(slugParam));

// Variables for pagination view
let page: any;
let uniqueTags: string[] = [];
let meta: any;

// Variables for post view
let entry: any;
let Content: any;

if (isPageNumber) {
  // This is a pagination request - show post list
  const allPostsByDate = sortPostsByDate(postEntries);
  const allDelphiPostsByDate = sortDelphiByDate(delphiEntries);
  const allCombinedPosts = [...allPostsByDate, ...allDelphiPostsByDate];

  // Sort combined posts by date
  const allCombinedByDate = allCombinedPosts.sort((a, b) => {
    const aDate = new Date(a.data.updatedDate ?? a.data.publishDate).valueOf();
    const bDate = new Date(b.data.updatedDate ?? b.data.publishDate).valueOf();
    return bDate - aDate;
  });

  // Get unique tags
  const postTags = getPostUniqueTags(postEntries);
  const delphiTags = getDelphiUniqueTags(delphiEntries);
  uniqueTags = [...new Set([...postTags, ...delphiTags])];

  // Manual pagination
  const pageSize = 10;
  const currentPage = parseInt(slugParam);
  const totalPages = Math.ceil(allCombinedByDate.length / pageSize);
  const startIndex = (currentPage - 1) * pageSize;
  const endIndex = startIndex + pageSize;
  const paginatedPosts = allCombinedByDate.slice(startIndex, endIndex);

  // Create page object
  page = {
    data: paginatedPosts,
    currentPage,
    lastPage: totalPages,
    url: {
      current: `/posts/${currentPage === 1 ? '' : currentPage}/`,
      prev: currentPage > 1 ? `/posts/${currentPage - 1 === 1 ? '' : currentPage - 1}/` : undefined,
      next: currentPage < totalPages ? `/posts/${currentPage + 1}/` : undefined,
    }
  };

  meta = {
    description: 'Ready my collection of posts and the things that interest me',
    title: 'Posts',
  };
} else {
  // This is a blog post request
  entry = allPosts.find(e => e.slug === slugParam);

  if (!entry) {
    return Astro.redirect('/404');
  }

  const rendered = await entry.render();
  Content = rendered.Content;
}
---

{isPageNumber ? (
  <PageLayout meta={meta}>
    <h1 class='title mb-6'>Posts</h1>
    <div class='grid gap-y-16 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
      <section aria-label='Blog post list'>
        <ul class='space-y-8 text-start'>
          {
            page.data.map((p: any) => (
              <li class='flex flex-col flex-wrap gap-2 sm:flex-row [&_q]:basis-full'>
                <PostPreview as='h2' post={p} withDesc />
              </li>
            ))
          }
        </ul>
        <Pagination page={page} />
      </section>
      {
        !!uniqueTags.length && (
          <aside>
            <h2 class="mb-4 flex items-center text-lg font-semibold">
              <svg aria-hidden="true" class="h-6 w-6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 0h24v24H0z" fill="none" stroke="none" />
                <path d="M7.859 6h-2.834a2.025 2.025 0 0 0 -2.025 2.025v2.834c0 .537 .213 1.052 .593 1.432l6.116 6.116a2.025 2.025 0 0 0 2.864 0l2.834 -2.834a2.025 2.025 0 0 0 0 -2.864l-6.117 -6.116a2.025 2.025 0 0 0 -1.431 -.593z" />
                <path d="M17.573 18.407l2.834 -2.834a2.025 2.025 0 0 0 0 -2.864l-7.117 -7.116" />
                <path d="M6 9h-.01" />
              </svg>
              Tags
            </h2>
            <ul class="flex flex-wrap gap-2 text-bgColor">
              {uniqueTags.map((tag) => (
                <li>
                  <a aria-label={`View all posts with the tag: ${tag}`} class="flex items-center justify-center rounded-lg bg-accent p-1" href={`/tags/${tag}/`}>
                    {tag}
                  </a>
                </li>
              ))}
            </ul>
            <span class="mt-4 block sm:text-end">
              <a aria-label="View all blog categories" class="sm:hover:text-accent" href="/tags/">
                View all →
              </a>
            </span>
          </aside>
        )
      }
    </div>
  </PageLayout>
) : (
  <PostLayout post={entry}>
    <article class="prose prose-cactus"><Content /></article>
  </PostLayout>
)}
