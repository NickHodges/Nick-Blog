---
interface Props {
	postSlug: string;
}

const { postSlug } = Astro.props;
---

<div class="comment-form-container mt-8 p-6 border border-gray-300 rounded-lg bg-gray-50 dark:bg-gray-800 dark:border-gray-700">
	<h3 class="text-2xl font-bold mb-4">Leave a Comment</h3>
	<form id="comment-form" class="space-y-4" data-post-slug={postSlug}>

		<div>
			<label for="author" class="block text-sm font-medium mb-1">
				Name <span class="text-red-500">*</span>
			</label>
			<input
				type="text"
				id="author"
				name="author"
				required
				maxlength="100"
				class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
			/>
		</div>

		<div>
			<label for="email" class="block text-sm font-medium mb-1">
				Email (optional, not public)
			</label>
			<input
				type="email"
				id="email"
				name="email"
				class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
			/>
		</div>

		<div>
			<label for="content" class="block text-sm font-medium mb-1">
				Comment <span class="text-red-500">*</span>
			</label>
			<textarea
				id="content"
				name="content"
				required
				maxlength="5000"
				rows="5"
				class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
			></textarea>
		</div>

		<div>
			<button
				type="submit"
				id="submit-button"
				class="px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed transition-all duration-200 flex items-center gap-2"
			>
				<span id="button-text">Submit Comment</span>
				<svg id="loading-spinner" class="hidden animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
					<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
					<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
				</svg>
			</button>
		</div>

		<div id="form-message" class="hidden mt-4 p-4 rounded-md"></div>
	</form>
</div>

<style>
	@keyframes pulse-glow {
		0%, 100% {
			box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.5);
		}
		50% {
			box-shadow: 0 0 0 8px rgba(59, 130, 246, 0);
		}
	}

	#submit-button.analyzing {
		animation: pulse-glow 2s ease-in-out infinite;
	}
</style>

<script>
	import { actions } from 'astro:actions';

	function createTextDiv(text: string, className: string): HTMLDivElement {
		const div = document.createElement('div');
		div.className = className;
		div.textContent = text;
		return div;
	}

	const form = document.getElementById('comment-form') as HTMLFormElement | null;
	const messageEl = document.getElementById('form-message');
	const submitButton = document.getElementById('submit-button') as HTMLButtonElement | null;
	const buttonText = document.getElementById('button-text');
	const spinner = document.getElementById('loading-spinner');

	if (form && messageEl && submitButton && buttonText && spinner) {
		const postSlug = form.dataset.postSlug || '';

		form.addEventListener('submit', async (e) => {
			e.preventDefault();

			// Show loading state
			submitButton.disabled = true;
			submitButton.classList.add('analyzing');
			buttonText.textContent = 'Analyzing with Respectify AI...';
			spinner.classList.remove('hidden');

			const formData = new FormData(form);

			try {
				const { data, error } = await actions.comments.submit({
					postSlug,
					author: formData.get('author') as string,
					email: (formData.get('email') as string) || undefined,
					content: formData.get('content') as string,
				});

				if (error) {
					messageEl.innerHTML = '<div class="font-semibold">An error occurred. Please try again.</div>';
					messageEl.className = 'mt-4 p-4 rounded-md bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200 border-2 border-red-300 dark:border-red-700';
					messageEl.classList.remove('hidden');
					return;
				}

				if (data.approved) {
					// Comment approved and published
					messageEl.innerHTML = '';
					messageEl.appendChild(createTextDiv(`✓ ${data.message}`, 'font-semibold text-lg mb-2'));
					messageEl.appendChild(createTextDiv(data.feedback, 'text-sm'));

					if (data.score !== undefined) {
						messageEl.appendChild(createTextDiv(`Respectfulness score: ${(data.score * 100).toFixed(0)}%`, 'text-xs mt-2 opacity-75'));
					}

					messageEl.className = 'mt-4 p-4 rounded-md bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200 border-2 border-green-300 dark:border-green-700';
					form.reset();

					// Reload page after 2 seconds to show the new comment
					setTimeout(() => {
						window.location.reload();
					}, 2000);
				} else {
					// Comment not approved - show feedback and allow revision
					messageEl.innerHTML = '';
					messageEl.appendChild(createTextDiv('⚠ Comment needs improvement', 'font-semibold text-lg mb-2'));
					messageEl.appendChild(createTextDiv(
						data.feedback || 'Your comment did not meet our respectfulness standards.',
						'mb-3',
					));

					if (data.suggestion) {
						const suggestionBox = document.createElement('div');
						suggestionBox.className = 'mt-3 p-3 bg-blue-50 dark:bg-blue-900 rounded border border-blue-200 dark:border-blue-700';
						suggestionBox.appendChild(createTextDiv('Suggestion:', 'font-semibold text-sm mb-1'));
						suggestionBox.appendChild(createTextDiv(data.suggestion, 'text-sm'));
						messageEl.appendChild(suggestionBox);
					}

					if (data.score !== undefined) {
						messageEl.appendChild(createTextDiv(`Respectfulness score: ${(data.score * 100).toFixed(0)}%`, 'text-xs mt-3 opacity-75'));
					}

					messageEl.appendChild(createTextDiv('Please revise your comment and try again.', 'mt-3 text-sm font-medium'));
					messageEl.className = 'mt-4 p-4 rounded-md bg-yellow-100 text-yellow-900 dark:bg-yellow-900 dark:text-yellow-200 border-2 border-yellow-300 dark:border-yellow-700';
				}

				messageEl.classList.remove('hidden');
			} catch {
				messageEl.innerHTML = '<div class="font-semibold">An error occurred. Please try again.</div>';
				messageEl.className = 'mt-4 p-4 rounded-md bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200 border-2 border-red-300 dark:border-red-700';
				messageEl.classList.remove('hidden');
			} finally {
				// Reset button state
				submitButton.disabled = false;
				submitButton.classList.remove('analyzing');
				buttonText.textContent = 'Submit Comment';
				spinner.classList.add('hidden');
			}
		});
	}
</script>
